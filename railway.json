{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run build --workspace=@darsly/api",
    "watchPatterns": ["**"]
  },
  "deploy": {
    "startCommand": "npm run start --workspace=@darsly/api",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
