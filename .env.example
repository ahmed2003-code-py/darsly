# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://darsly:darsly_dev_password@localhost:5434/darsly?schema=public"

# ── API ───────────────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173
# Comma-separated origins allowed by CORS + the video domain-lock check
ALLOWED_ORIGINS=http://localhost:5173

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=900        # seconds (15 min)
JWT_REFRESH_TTL=2592000   # seconds (30 days)
# Dev OTP: when true, OTP codes are logged to console instead of sent via SMS
OTP_DEV_MODE=true
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# ── Sessions & device control (Teacher-Security defaults) ────────────────
MAX_CONCURRENT_SESSIONS_DEFAULT=2

# ── Video / streaming ─────────────────────────────────────────────────────
SIGNED_URL_TTL_SECONDS=300
HLS_KEY_ROTATION_SECONDS=3600
STORAGE_DRIVER=local           # local | s3
STORAGE_LOCAL_PATH=./storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=darsly-media
S3_ACCESS_KEY=darsly
S3_SECRET_KEY=darsly_dev_password

# ── Payments ──────────────────────────────────────────────────────────────
PAYMENT_GATEWAY=mock           # mock | paymob | fawry | stripe
PLATFORM_COMMISSION_DEFAULT=20 # percent, overridable per-teacher by super admin
CURRENCY=EGP

# ── Web (Vite) ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
PAYMENT_LISTENER_KEY=change-me-listener-secret   # shared secret for the Android notification listener

# ── Academy (workspace) layer ─────────────────────────────────────────────
# Feature flag for the academy context + membership/permission guards (Phase 2).
# Set to "false" to kill-switch the academy-aware endpoints during rollout.
ACADEMY_CONTEXT_ENABLED=true

# ── Academy Studio (AI site generation) ───────────────────────────────────
# Master kill-switch for the whole AI-site feature. Ships OFF; flip to "true"
# only after the media pipeline is deployed AND (in prod) STORAGE_DRIVER=s3,
# OPENAI_API_KEY and AI_MODEL are set — config validation enforces this.
AI_ACADEMY_ENABLED=false
# Backend-only OpenAI credential. Never expose this to the frontend.
OPENAI_API_KEY=
AI_MODEL=gpt-5
# Model token prices in cents per million tokens (set to your model's pricing).
AI_PRICE_IN_PER_MTOKEN=300
AI_PRICE_OUT_PER_MTOKEN=1500
# Month-to-date generation spend ceiling; generation is refused past this.
AI_MONTHLY_BUDGET_CENTS=50000
# Background worker: set false on replicas that should not process jobs.
WORKER_ENABLED=true
WORKER_CONCURRENCY=3
# Require admin approval before a first site publish goes public. Off by default
# (publishes go live immediately; admins can still take a site down).
ACADEMY_SITE_MODERATION=false
